# Optional. The app uses a local deterministic AI fallback without this key.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=low
OPENAI_TIMEOUT_SECONDS=45
OPENAI_MAX_RETRIES=2
OPENAI_MAX_TOOL_ROUNDS=2

# Google OAuth login. Create a Web application OAuth client in Google Cloud.
# Authorized redirect URI for the default local setup:
# http://127.0.0.1:3000/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
APP_BASE_URL=http://127.0.0.1:3000
# Optional explicit override. Normally FlowMind uses the browser origin.
GOOGLE_OAUTH_REDIRECT_URI=
APP_COOKIE_SECURE=false

# SQLite database file. Relative paths are resolved from the project root.
FLOWMIND_DATABASE_PATH=data/workflows.sqlite3

# Live workflow integrations. Gmail requires 2-Step Verification and an app password.
GMAIL_EMAIL=
GMAIL_APP_PASSWORD=
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=
NOTION_API_TOKEN=
# Preferred for current Notion API versions.
NOTION_DATA_SOURCE_ID=
# Legacy fallback. FlowMind resolves this to its single child data source.
NOTION_DATABASE_ID=

# Optional server overrides.
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
# Enabled by default so edits under src/ are picked up while developing.
BACKEND_RELOAD=true
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=3000
